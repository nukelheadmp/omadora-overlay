#!/usr/bin/env bash

active_window="$(hyprctl activewindow -j)"
active_pid="$(jq -r '.pid // empty' <<<"$active_window")"
active_class="$(jq -r '.class // empty' <<<"$active_window")"

fallback() {
  printf '%s\n' "$HOME"
  exit 0
}

[[ -n "$active_pid" ]] || fallback

case "$active_class" in
Alacritty | kitty | com.mitchellh.ghostty | foot) ;;
*) fallback ;;
esac

# Find descendant processes of the terminal.
mapfile -t pids < <(
  pstree -p "$active_pid" |
    grep -oP '\(\K[0-9]+(?=\))' |
    tail -n +2
)

for pid in "${pids[@]}"; do
  cwd="$(readlink -f "/proc/$pid/cwd" 2>/dev/null)" || continue
  exe="$(readlink -f "/proc/$pid/exe" 2>/dev/null)" || continue

  if [[ -d "$cwd" ]] && grep -Fxqs "$exe" /etc/shells; then
    printf '%s\n' "$cwd"
    exit 0
  fi
done

fallback

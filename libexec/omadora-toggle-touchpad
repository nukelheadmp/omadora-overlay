#!/bin/bash

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# Enable, disable, or toggle the touchpad

STATE_FILE="$HOME/.local/state/omadora/toggles/hypr/touchpad-disabled.lua"

device="$(omadora_run omadora-hw-touchpad)"

if [[ -z $device ]]; then
  echo "No touchpad device found" >&2
  exit 1
fi

enable() {
  hyprctl eval "hl.device({ name = \"$device\", enabled = true })" >/dev/null
  rm -f "$STATE_FILE"
  notify-send -u low "󰟸    Touchpad enabled"
}

disable() {
  hyprctl eval "hl.device({ name = \"$device\", enabled = false })" >/dev/null
  mkdir -p "$(dirname "$STATE_FILE")"
  printf 'hl.device({ name = "%s", enabled = false })\n' "$device" >"$STATE_FILE"
  notify-send -u low "󰟸    Touchpad disabled"
}

case "${1:-toggle}" in
on) enable ;;
off) disable ;;
toggle) if [[ -f $STATE_FILE ]]; then enable; else disable; fi ;;
esac

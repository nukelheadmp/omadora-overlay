#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# shellcheck source=lib/theme.sh
source "$OMADORA_LIB_DIR/theme.sh"

yes=false

while [[ $# -gt 0 ]]; do
  case "$1" in
  -y | --yes)
    yes=true
    shift
    ;;
  -*)
    die "unknown option $1"
    ;;
  *)
    [[ -z "${url:-}" ]] || die "unexpected argument $1"
    url="$1"
    shift
    ;;
  esac
done

url="${url:-}"

[[ -n "$url" ]] || {
  die "missing theme repository URL"
}

theme_name="$(
  basename "$url" .git |
    sed -E 's/^(omarchy|omadora)-//; s/-theme$//'
)"

theme_path="$OMADORA_USER_THEMES_DIR/$theme_name"

if [[ "$yes" != true ]]; then
  cat <<'EOF'

+---------------------------------------------------------------------+
| Warning: third-party theme install                                  |
+---------------------------------------------------------------------+
| Themes can include files that run commands on your computer.        |
| Only install from trusted repositories, and verify the files first. |
+---------------------------------------------------------------------+

EOF

  confirm "Install third-party theme '$theme_name'?" || {
    info "Theme install cancelled."
    exit 0
  }
fi

info "Installing theme: $theme_name"

# Remove existing theme if present
if [ -d "$theme_path" ]; then
  rm -rf "$theme_path"
fi

# Clone the repo directly into the user themes directory
git clone "$url" "$theme_path" ||
  die "failed to clone theme repository"

# Apply the new theme
"$OMADORA_LIBEXEC_DIR/omadora-theme-set" "$theme_name" ||
  die "failed to apply theme"

info "Installed theme: $theme_name"

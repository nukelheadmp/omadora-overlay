#!/bin/bash

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../lib/common/init.sh"

# Clear the internal-monitor-disable toggle if no external display is connected.

TOGGLE="$HOME/.local/state/omadora/toggles/hypr/internal-monitor-disable.lua"

if [[ -f $TOGGLE ]] && ! omadora_run omadora-hw-external-monitors; then
  rm -f "$TOGGLE"
fi

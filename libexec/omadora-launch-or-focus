#!/bin/bash

# Launch an app or focus an existing window matching a pattern

if (($# == 0)); then
  echo "Usage: omadora-launch-or-focus <window-pattern> [-- <launch-command> [args...]]"
  exit 1
fi

WINDOW_PATTERN="$1"
shift

if [[ ${1:-} == "--" ]]; then
  shift
fi

WINDOW_ADDRESS=$(hyprctl clients -j | jq -r --arg p "$WINDOW_PATTERN" '.[]|select((.class|test("\\b" + $p + "\\b";"i")) or (.title|test("\\b" + $p + "\\b";"i")))|.address' | head -n1)

if [[ -n $WINDOW_ADDRESS ]]; then
  hyprctl dispatch "hl.dsp.focus({ window = \"address:$WINDOW_ADDRESS\" })" >/dev/null 2>&1 || hyprctl dispatch focuswindow "address:$WINDOW_ADDRESS"
elif (($# > 0)); then
  exec "$@"
else
  exec uwsm-app -S both -- "$WINDOW_PATTERN"
fi

#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=lib/common/init.sh
source "$(dirname "${BASH_SOURCE[0]}")/../../lib/common/init.sh"

# =========================================================
# Omadora Weather Check
# =========================================================

STATE_DIR="${OMADORA_STATE_HOME}/weather"
CACHE_DIR="${OMADORA_CACHE_HOME}/weather"

STATE_FILE="$STATE_DIR/state.json"
RAW_FILE="$CACHE_DIR/raw.json"

ensure_dir "$STATE_DIR" "$CACHE_DIR"

CURL_OPTS=(
  -fsS
  --connect-timeout 5
  --max-time 15
  --retry 1
  --retry-delay 1
)

# ---------------------------------------
# IP geolocation
# ---------------------------------------
get_location() {
  curl "${CURL_OPTS[@]}" https://ipapi.co/json/ |
    jq -r '{
      source: "ipapi",
      lat: .latitude,
      lon: .longitude,
      city: .city,
      country: .country_name,
      country_code: .country_code
    }'
}

# ---------------------------------------
# Get units
# ---------------------------------------
get_units() {
  local mode="${OMADORA_WEATHER_UNITS:-auto}"
  local system

  case "$mode" in
  metric | imperial)
    system="$mode"
    ;;
  auto)
    measurement="$(locale measurement 2>/dev/null || true)"

    case "$measurement" in
    1) system="metric" ;;
    2) system="imperial" ;;
    *)
      case "${LANG:-}" in
      *US* | *LR* | *MM*) system="imperial" ;;
      *) system="metric" ;;
      esac
      ;;
    esac
    ;;
  *)
    mode="auto"
    system="metric"
    ;;
  esac

  printf '{"mode":"%s","system":"%s"}\n' "$mode" "$system"
}

# ---------------------------------------
# Open-Meteo fetch
# ---------------------------------------
fetch_weather() {
  local lat="$1"
  local lon="$2"
  local system="$3"

  local wind_speed_unit="kmh"
  local temperature_unit="celsius"
  local precipitation_unit="mm"

  if [[ "$system" == "imperial" ]]; then
    wind_speed_unit="mph"
    temperature_unit="fahrenheit"
    precipitation_unit="inch"
  fi

  curl "${CURL_OPTS[@]}" \
    "https://api.open-meteo.com/v1/forecast?\
latitude=${lat}\
&longitude=${lon}\
&hourly=uv_index,precipitation_probability\
&daily=weather_code,temperature_2m_max,temperature_2m_min,uv_index_max,precipitation_probability_max,sunrise,sunset\
&current=temperature_2m,relative_humidity_2m,apparent_temperature,is_day,precipitation,weather_code,cloud_cover,pressure_msl,wind_speed_10m,wind_gusts_10m,wind_direction_100m,visibility,uv_index\
&wind_speed_unit=${wind_speed_unit}\
&temperature_unit=${temperature_unit}\
&precipitation_unit=${precipitation_unit}\
&timeformat=iso8601\
&timezone=auto\
&forecast_days=7"
}

# ---------------------------------------
# Condition mapping (WMO)
# ---------------------------------------
get_condition() {
  case "$1" in
  0) echo "clear" ;;
  1 | 2 | 3) echo "cloudy" ;;
  45 | 48) echo "fog" ;;
  51 | 53 | 55) echo "drizzle" ;;
  56 | 57) echo "freezing_drizzle" ;;
  61 | 63 | 65) echo "rain" ;;
  66 | 67) echo "freezing_rain" ;;
  71 | 73 | 75) echo "snow" ;;
  77) echo "snow_grains" ;;
  80 | 81 | 82) echo "showers" ;;
  85 | 86) echo "snow_showers" ;;
  95) echo "thunderstorm" ;;
  96 | 99) echo "severe_thunderstorm" ;;
  *) echo "unknown" ;;
  esac
}

# ---------------------------------------
# Wind class (Beaufort scale 0–12)
# ---------------------------------------
get_wind_class() {
  local speed="$1"
  local unit="$2"

  local ms

  case "$unit" in
  km/h | kmh)
    ms=$(awk -v v="$speed" 'BEGIN { print v / 3.6 }')
    ;;
  mph)
    ms=$(awk -v v="$speed" 'BEGIN { print v * 0.44704 }')
    ;;
  knots | kt | kt.)
    ms=$(awk -v v="$speed" 'BEGIN { print v * 0.514444 }')
    ;;
  m/s | ms | mps | "")
    ms="$speed"
    ;;
  *)
    ms="$speed"
    ;;
  esac

  awk -v w="$ms" 'BEGIN {
    if      (w < 0.3)  print "calm"
    else if (w < 1.6)  print "light_air"
    else if (w < 3.4)  print "light_breeze"
    else if (w < 5.5)  print "gentle_breeze"
    else if (w < 8.0)  print "moderate_breeze"
    else if (w < 10.8) print "fresh_breeze"
    else if (w < 13.9) print "strong_breeze"
    else if (w < 17.2) print "near_gale"
    else if (w < 20.8) print "gale"
    else if (w < 24.5) print "strong_gale"
    else if (w < 28.5) print "storm"
    else if (w < 32.7) print "violent_storm"
    else               print "hurricane"
  }'
}

# ---------------------------------------
# UV class (WHO)
# ---------------------------------------
get_uv_class() {
  awk -v u="$1" 'BEGIN {
    if (u < 3) print "low"
    else if (u < 6) print "moderate"
    else if (u < 8) print "high"
    else if (u < 11) print "very_high"
    else print "extreme"
  }'
}

# ---------------------------------------
# Fallback
# ---------------------------------------
fallback_state() {
  jq -n '{
    meta:{valid:false},
    location:{},
    weather:{
      source: null,
      current_units:{},
      current:{},
      daily_units:{},
      daily:{},
      derived:{icon:"",condition:"unknown"},
      signals:{},
    }
  }'
}

# ---------------------------------------
# Reducer
# ---------------------------------------
reduce_weather() {
  local data="$1"

  utc_offset_seconds=$(jq -r '.utc_offset_seconds' <<<"$data")

  # CURRENT
  current_units=$(jq -r '.current_units' <<<"$data")
  current=$(jq -r '.current' <<<"$data")

  # DAILY
  daily_units=$(jq -r '.daily_units' <<<"$data")
  daily=$(jq -r '.daily | with_entries(.value |= .[0])' <<<"$data")

  # DERIVED
  weather_code=$(jq -r '.current.weather_code' <<<"$data")
  wind_speed_10m=$(jq -r '.current.wind_speed_10m' <<<"$data")
  wind_speed_unit=$(jq -r '.current_units.wind_speed_10m' <<<"$data")
  uv_index=$(jq -r '.current.uv_index' <<<"$data")
  uv_index_max=$(jq -r '.daily.uv_index_max[0]' <<<"$data")

  condition=$(get_condition "$weather_code")
  wind_class=$(get_wind_class "$wind_speed_10m" "$wind_speed_unit")
  uv_class=$(get_uv_class "$uv_index")
  uv_max_class=$(get_uv_class "$uv_index_max")

  # VIEW ICON
  is_day=$(jq -r '.current.is_day' <<<"$data")

  local icon=""
  case "$condition:$is_day" in
  clear:1) icon="󰖙" ;;
  clear:0) icon="󰖔" ;;
  cloudy:*) icon="" ;;
  fog:*) icon="" ;;
  drizzle:*) icon="" ;;
  freezing_drizzle:*) icon="" ;;
  rain:*) icon="" ;;
  showers:*) icon="" ;;
  snow:*) icon="" ;;
  snow_showers:*) icon="" ;;
  thunderstorm:*) icon="" ;;
  severe_thunderstorm:*) icon="" ;;
  esac

  jq -n \
    --argjson utc_offset_seconds "$utc_offset_seconds" \
    --argjson current_units "$current_units" \
    --argjson current "$current" \
    --argjson daily_units "$daily_units" \
    --argjson daily "$daily" \
    --arg condition "$condition" \
    --arg icon "$icon" \
    --arg wind_class "$wind_class" \
    --arg uv_class "$uv_class" \
    --arg uv_max_class "$uv_max_class" \
    '
    {
      source:"open-meteo",

      utc_offset_seconds:$utc_offset_seconds,

      current_units:$current_units,

      current:$current,

      daily_units:$daily_units,

      daily:$daily,

      derived:{
        icon:$icon,
        condition:$condition,
        wind_class:$wind_class,
        uv_index_class:$uv_class,
        uv_index_max_class:$uv_max_class
      },
    }
  '
}

# ---------------------------------------
# Compile
# ---------------------------------------
compile_output() {
  local loc="$1"
  local units="$2"
  local reduced="$3"

  jq -n \
    --argjson location "$loc" \
    --argjson units "$units" \
    --argjson weather "$reduced" \
    '
    {
      meta:{
        valid: true,
        timestamp:(now|floor)
      },
      location: $location,
      units: $units,
      weather: $weather
    }
  '
}

# ---------------------------------------
# Waybar
# ---------------------------------------
waybar_module_refresh() {
  pkill -RTMIN+11 waybar
}

# ---------------------------------------
# Main
# ---------------------------------------
info 'Starting weather check...'

info 'Fetching location data...'
if ! loc=$(get_location); then
  error "Failed to fetch location data, writing fallback state."
  fallback_state >"$STATE_FILE"
  exit 0
fi

info 'Getting unit preference...'
units=$(get_units || true)

lat=$(jq -r '.lat // empty' <<<"$loc")
lon=$(jq -r '.lon // empty' <<<"$loc")
system=$(jq -r '.system // empty' <<<"$units")

if [[ -z "$lat" || -z "$lon" || -z "$system" ]]; then
  error "Failed to get location or unit data, writing fallback state."
  fallback_state >"$STATE_FILE"
  exit 0
fi

info 'Fetching weather data...'
if ! raw=$(fetch_weather "$lat" "$lon" "$system"); then
  error "Failed to fetch weather data, writing fallback state."
  fallback_state >"$STATE_FILE"
  exit 0
fi

printf '%s' "$raw" >"$RAW_FILE"

info 'Reducing weather data...'
if ! reduced=$(reduce_weather "$raw"); then
  error "Failed to reduce weather data, writing fallback state."
  fallback_state >"$STATE_FILE"
  exit 0
fi

info 'Compiling state...'
if ! compiled=$(compile_output "$loc" "$units" "$reduced"); then
  error "Failed to compile state, writing fallback state."
  fallback_state >"$STATE_FILE"
  exit 0
fi

info 'Writing state...'
printf '%s' "$compiled" >"$STATE_FILE"

waybar_module_refresh ||
  debug "Failed to update Waybar module"

info 'Finished weather check.'
